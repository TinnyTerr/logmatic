{
	"name": "logmatic",
	"version": "1.5.0",
	"homepage": "https://github.com/tinnyterr/logmatic#readme",
	"bugs": {
		"url": "https://github.com/tinnyterr/logmatic/issues"
	},
	"license": "MPL-2.0",
	"author": "Lewis McDonald <l.mcdonald@dmnet.uk> (https://e-z.bio/tinnyterr)",
	"repository": {
		"type": "git",
		"url": "https://github.com/tinnyterr/logmatic.git"
	},
	"exports": {
		"import": "./dist/es6/index.mjs",
		"require": "./dist/cjs/index.js"
	},
	"types": "./dist/index.d.ts",
	"scripts": {
		"build": "npx tsup --format esm -d dist/esm && npx tsup --format cjs -d dist/cjs && npx tsc",
		"clean": "rm -rf *.log */*.log dist node_modules",
		"compile": "npm run clean && npm i && npm run prestart",
		"prestart": "npm run lint && npm run build",
		"lint": "rm -rf dist && npx @biomejs/biome check --write",
		"test": "npm run prestart && node tests/test.cjs && node tests/test.mjs"
	},
	"devDependencies": {
		"@biomejs/biome": "1.8.3",
		"@types/estree": "^1.0.5",
		"@types/json-schema": "^7.0.15",
		"@types/node": "^18.19.30",
		"eslint": "^9.9.0",
		"globals": "^15.9.0",
		"prettier": "3.3.3",
		"tsup": "^8.2.4",
		"typescript": "^5.4.4"
	},
	"dependencies": {
		"console-log-colors": "^0.5.0",
		"json-colorizer": "^3.0.1"
	}
}
